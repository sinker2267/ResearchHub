# ResearchHub 环境变量
# 复制为 .env 并修改

# 数据库
POSTGRES_DB=researchhub
POSTGRES_USER=researchhub
POSTGRES_PASSWORD=change-me-in-production

# 后端
SERVER_PORT=8080
JWT_SECRET=generate-a-random-secret-using-openssl-rand-base64-64
CORS_ORIGINS=https://researchhub.example.com,http://localhost
UPLOAD_DIR=/app/uploads
